@model IEnumerable<MVRLJDGA.BusinessLogic.DTOs.BookDto>

@{
    ViewData["Title"] = "Gestión de Libros";
}
<div class="container mt-4">
    <h2 class="text-primary">Lista de Libros</h2>
    
    <p>
        <a asp-action="Create" class="btn btn-success">Crear Nuevo Libro</a>
    </p>
    
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Título</th>
                <th>Precio</th>
                <th>Stock</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Title)</td>
                    <td>@Html.DisplayFor(modelItem => item.SalePrice)</td>
                    <td>@Html.DisplayFor(modelItem => item.Stock)</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a> |
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>