@model IEnumerable<MVRLJDGA.BusinessLogic.DTOs.BookDto>

@{
    ViewData["Title"] = "Gestión de Libros";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold"><i class="bi bi-journal-bookmark"></i> Gestión Integral de Libros</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> Añadir Nuevo Libro
        </a>
    </div>

    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Portada</th>
                        <th>Título</th>
                        <th>Precio Venta</th>
                        <th>Stock</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="Portada" style="width: 50px; height: 70px; object-fit: cover;" class="rounded shadow-sm" />
                                }
                                else
                                {
                                    <div class="bg-light d-flex align-items-center justify-content-center rounded" style="width: 50px; height: 70px; border: 1px dashed #ccc;">
                                        <i class="bi bi-image text-muted"></i>
                                    </div>
                                }
                            </td>
                            <td class="fw-bold text-dark">@item.Title</td>
                            <td class="text-success fw-bold">$@item.SalePrice</td>
                            <td>
                                @if (item.Stock < 5)
                                {
                                    <span class="badge bg-danger">¡Crítico! @item.Stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">@item.Stock unidades</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Editar">
                                        <i class="bi bi-pencil-square"></i> Editar
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" title="Eliminar">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>