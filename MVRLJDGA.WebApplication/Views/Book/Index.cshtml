@model IEnumerable<MVRLJDGA.BusinessLogic.DTOs.BookDto>

@{
    ViewData["Title"] = "Gestión de Libros";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold"><i class="bi bi-journal-bookmark"></i> Gestión Integral de Libros</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> Añadir Nuevo Libro
        </a>
    </div>

    <div class="card mb-4 shadow-sm border-0">
        <div class="card-body bg-light rounded">
            <form method="get" asp-action="Index" class="row g-3 align-items-center">
                <div class="col-md-7">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="searchTerm" class="form-control border-start-0"
                               placeholder="Buscar por título del libro..." value="@ViewData["CurrentFilter"]">
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="genreFilter" class="form-select" asp-items="@(ViewBag.Genres as SelectList)">
                        <option value="">-- Todos los géneros --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-filter"></i> Filtrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Portada</th>
                        <th>Título</th>
                        <th>Precio Venta</th>
                        <th>Stock</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                <i class="bi bi-info-circle"></i> No se encontraron libros con esos criterios.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="Portada"
                                         style="width: 60px; height: 85px; object-fit: cover;"
                                         class="rounded shadow-sm border" />
                                }
                                else
                                {
                                    <div class="bg-light d-flex align-items-center justify-content-center rounded border"
                                         style="width: 60px; height: 85px;">
                                        <i class="bi bi-image text-muted" style="font-size: 1.5rem;"></i>
                                    </div>
                                }
                            </td>
                            <td class="fw-bold text-dark ps-3">@item.Title</td>
                            <td class="text-success fw-bold">$@item.SalePrice</td>
                            <td>
                                @if (item.Stock < 5)
                                {
                                    <span class="badge bg-danger">¡Stock Crítico! @item.Stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">@item.Stock unidades</span>
                                }
                            </td>
                          
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm shadow-sm">
                                        <i class="bi bi-pencil-square"></i> Editar
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm shadow-sm">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>