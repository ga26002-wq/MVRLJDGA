@model MVRLJDGA.BusinessLogic.DTOs.BookDto

@{
    ViewData["Title"] = "Nuevo Libro";
}

<div class="container mt-4">

    <h3 class="text-secondary">Crear Libro</h3>

    <hr />

    <div class="row">

        <div class="col-md-6">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">

                    <label asp-for="Title" class="control-label fw-bold">
                        Título
                    </label>

                    <input asp-for="Title" class="form-control" />

                    <span asp-validation-for="Title" class="text-danger"></span>

                </div>

                <div class="form-group mb-3">

                    <label asp-for="PublisherId" class="control-label fw-bold">
                        Editorial
                    </label>

                    <div class="form-group mb-3">
                        <label asp-for="PublisherId" class="control-label fw-bold">Género / Categoría</label>
    
                        <select asp-for="PublisherId"
                                class="form-control"
                                asp-items="@(ViewBag.PublisherList as SelectList)">
                            <option value="">-- Seleccione un género --</option>
                        </select>
    
                        <span asp-validation-for="PublisherId" class="text-danger"></span>
                    </div>

                <div class="form-group mb-3">

                    <label asp-for="SalePrice" class="control-label fw-bold">
                        Precio de Venta
                    </label>

                    <input asp-for="SalePrice" class="form-control" />

                    <span asp-validation-for="SalePrice" class="text-danger"></span>

                </div>

                <div class="form-group mb-3">

                    <label asp-for="Stock" class="control-label fw-bold">
                        Stock
                    </label>

                    <input asp-for="Stock" class="form-control" />

                    <span asp-validation-for="Stock" class="text-danger"></span>

                </div>

                <div class="form-group">

                    <input type="submit"
                           value="Crear"
                           class="btn btn-primary" />

                    <a asp-action="Index"
                           class="btn btn-secondary">

                        Regresar

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>