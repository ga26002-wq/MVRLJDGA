@model MVRLJDGA.BusinessLogic.DTOs.PublisherDto

@{
    ViewData["Title"] = "Crear Editorial";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="card-title mb-0 fw-bold">Crear Nueva Editorial</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-4">
                            <label asp-for="PublisherName" class="form-label fw-bold">Nombre de la Editorial</label>
                            <input asp-for="PublisherName" class="form-control" placeholder="Ej. Editorial Santillana" required />
                            <span asp-validation-for="PublisherName" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Regresar</a>
                            <button type="submit" class="btn btn-primary px-4">Guardar Editorial</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}