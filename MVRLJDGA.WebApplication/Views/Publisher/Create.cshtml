@model MVRLJDGA.BusinessLogic.DTOs.PublisherDto

@{
    ViewData["Title"] = "Registrar Nueva Publicación";
}

<div class="container mt-4">
    <div class="card shadow-sm col-md-6 mx-auto">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0 fw-bold"><i class="bi bi-cloud-arrow-up"></i> Registrar Publicación</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="PublisherName" class="form-label fw-bold">Nombre o Título del Registro de Publicación</label>
                    <input asp-for="PublisherName" class="form-control" placeholder="Ej. Publicación Médica 2026 / Editorial Alfa" required />
                    <span asp-validation-for="PublisherName" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-success fw-bold">Guardar Registro</button>
                </div>
            </form>
        </div>
    </div>
</div>