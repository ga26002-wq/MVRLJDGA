@model IEnumerable<MVRLJDGA.BusinessLogic.DTOs.PublisherDto>

@{
    ViewData["Title"] = "Gestión de Editoriales";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary fw-bold">Gestión de Editoriales</h2>
        <a asp-action="Create" class="btn btn-success px-4">
            <i class="bi bi-plus-circle"></i> Añadir Nueva Editorial
        </a>
    </div>
    
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4" style="width: 15%;">Código ID</th>
                        <th>Nombre de la Editorial</th>
                        <th class="text-center" style="width: 25%;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">No se encontraron editoriales registradas.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">#@item.Id</td>
                                <td class="fw-semibold">@item.PublisherName</td>
                                <td class="text-center">
                                    <span class="badge bg-secondary px-3 py-2">Módulo Lectura</span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>