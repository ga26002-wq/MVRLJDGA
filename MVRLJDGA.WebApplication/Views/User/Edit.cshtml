@model MVRLJDGA.BusinessLogic.DTOs.UserDto

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h5 class="card-title mb-0 fw-bold">Modificar Cuenta de Usuario</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <input type="hidden" asp-for="Id" />

                        <div class="form-group mb-3">
                            <label asp-for="AccountName" class="form-label fw-bold">Nombre de Cuenta</label>
                            <input asp-for="AccountName" class="form-control" placeholder="Ej. mruballo" required />
                            <span asp-validation-for="AccountName" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="RoleId" class="form-label fw-bold">Rol de Usuario</label>
                            <select asp-for="RoleId" class="form-select" asp-items="ViewBag.Roles" required>
                                <option value="">-- Selecciona un Rol --</option>
                            </select>
                            <span asp-validation-for="RoleId" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="AccessKey" class="form-label fw-bold">Clave de Acceso / Contraseña</label>
                            <input asp-for="AccessKey" class="form-control" type="password" required />
                            <span asp-validation-for="AccessKey" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Regresar</a>
                            <button type="submit" class="btn btn-warning fw-bold px-4 text-dark">Actualizar</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}