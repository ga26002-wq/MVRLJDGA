@model MVRLJDGA.BusinessLogic.DTOs.UserDto

@{
    ViewData["Title"] = "Eliminar Usuario";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="card-title mb-0 fw-bold">¿Estás seguro de eliminar este usuario?</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4">
                        <table class="table table-borderless">
                            <tr>
                                <td class="fw-bold text-muted" style="width: 40%;">Nombre de Cuenta:</td>
                                <td class="fw-bold text-dark">@Model.AccountName</td>
                            </tr>
                            <tr>
                                <td class="fw-bold text-muted">Rol Asignado:</td>
                                <td>
                                    <span class="badge bg-info text-dark px-3 py-2 fw-bold">
                                        @(string.IsNullOrEmpty(Model.RoleTitle) ? $"Rol ID: {Model.RoleId}" : Model.RoleTitle)
                                    </span>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-end gap-2">
                            <button type="submit" class="btn btn-danger fw-bold px-4">Confirmar Eliminación</button>
                            <a asp-action="Index" class="btn btn-secondary px-4">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>